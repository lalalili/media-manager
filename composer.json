{
    "name": "lalalili/media-manager",
    "description": "Reusable Filament and Livewire media manager for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "livewire/livewire": "^3.0|^4.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Lalalili\\MediaManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lalalili\\MediaManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\MediaManager\\MediaManagerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --no-progress",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}
