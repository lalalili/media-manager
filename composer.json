{
    "name": "lalalili/media-manager",
    "description": "Reusable Filament and Livewire media manager for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "livewire/livewire": "^3.0|^4.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Lalalili\\MediaManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\MediaManager\\MediaManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
